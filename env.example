# Mailgun SMTP
SMTP_HOST=change-me
SMTP_PORT=587
SMTP_USER=change-me
SMTP_PASS=change-me

SESSION_SECRET=change-me
QUESTIONS_KEY=change-me

# Redis
# Dev: local install on 127.0.0.1, no password. DB 0 for dev, DB 1 for e2e tests.
# Prod (in /opt/weeqlash/.env): redis://:${REDIS_PASSWORD}@redis:6379 — container, password required.
REDIS_URL=redis://127.0.0.1:6379
# REDIS_PASSWORD is prod-only; do not set locally.
