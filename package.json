{
  "name": "sraz-multiplayer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "type": "module",
  "scripts": {
    "server": "npm run dev --workspace=server",
    "client": "npm start --workspace=client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint server/ client/ tests/",
    "lint:fix": "eslint server/ client/ tests/ --fix",
    "lint:css": "node scripts/check-unused-selectors.js",
    "lint:all": "npm run lint && npm run lint:css"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.4.0",
    "vitest": "^3.0.0"
  }
}
